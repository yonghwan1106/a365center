# 이 파일을 복사해서 .env.local 로 저장한 뒤 실제 값을 채우세요.
# .env.local 은 .gitignore에 의해 자동 제외됩니다 (커밋 금지)

# Google AI Studio (https://aistudio.google.com) 에서 발급받은 Gemini API 키
# ⚠ 절대 클라이언트 코드에 직접 박지 마세요. 이 파일을 통해서만 서버에서 사용됩니다.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
